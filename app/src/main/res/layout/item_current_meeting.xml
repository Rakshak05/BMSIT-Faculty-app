<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/text_secondary"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/textViewMeetingTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/textViewMeetingTime"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="Meeting Title"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Time for the meeting -->
            <TextView
                android:id="@+id/textViewMeetingTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="00:00"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?android:attr/colorPrimary" />

        </RelativeLayout>

        <TextView
            android:id="@+id/textViewMeetingDateTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Date and Time"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

        <!-- Expanded content that will be shown/hidden -->
        <LinearLayout
            android:id="@+id/expandedContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/textViewMeetingLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Location: Conference Hall"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/textViewMeetingAttendees"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="For: All Faculty"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

            <!-- Added TextView to show who hosted the meeting -->
            <TextView
                android:id="@+id/textViewMeetingHost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Hosted by: "
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:textStyle="italic" />

            <!-- Record meeting button for host -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonRecordMeeting"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Record Meeting"
                android:visibility="gone" />

            <!-- End meeting button for host -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonEndMeeting"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/colorError"
                android:text="End Meeting"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>